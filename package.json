    "jiti": "^2.7.0",
    "jsdom": "^26.1.0",
    "obsidian": "^1.13.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  },
  "bugs": {
    "url": "https://github.com/swartzrock/obsidian-settings-float-plugin/issues"
